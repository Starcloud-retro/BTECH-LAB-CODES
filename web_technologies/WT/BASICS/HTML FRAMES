<!DOCTYPE html>
<html>
<head>
<title>HTML Frames Demonstration</title>
</head>
<frameset rows="20%, 60%" border="8">
<!-- Top frame -->
<frame src="header.html" name="top">
<!-- Bottom frames divided into columns -->
<frameset cols="30%, 70%">
<frame src="menu.html" name="left">
<frame src="content.html" name="right">
</frameset>
</frameset>
</html> 
