{
  "$schema": "https://ui.shadcn.com/schema.json",

  /* Style configuration */
  "style": "default",
  "rsc": false,
  "tsx": true,

  /* Tailwind integration */
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/index.css",
    "baseColor": "slate",
    "cssVariables": true,
    "prefix": ""
  },

  /* Path aliases */
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  }
}
